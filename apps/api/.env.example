# Pooled PostgreSQL connection string — used for all queries.
# On Vercel + Neon these two are injected automatically by the integration.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Direct (unpooled) connection string — used only for `prisma migrate`.
# Locally, with no pooler in front, set this to the same value as DATABASE_URL.
DATABASE_URL_UNPOOLED="postgresql://user:password@host/dbname?sslmode=require"

# Secret used to sign admin session JWTs - use a long random string.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="change-me-to-a-long-random-string"

# Admin login credentials
ADMIN_USERNAME="admin"
# Generate with: npm run hash-password --workspace apps/api -- "your-password"
ADMIN_PASSWORD_HASH="$2a$10$replace-with-generated-bcrypt-hash"

# Comma-separated list of allowed origins for the deployed frontend.
# In production set this to your real domain, e.g. https://saltandlight.vercel.app
CORS_ORIGIN="http://localhost:5173"

# Vercel Blob store token, used for poster uploads on updates.
# On Vercel this is injected automatically when you create a Blob store.
# For local uploads, copy it from the store's .env.local tab (or `vercel env pull`).
# Leave blank and everything except poster uploads still works.
BLOB_READ_WRITE_TOKEN=""

PORT=3001
