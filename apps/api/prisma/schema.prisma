generator client {
  provider = "prisma-client-js"
  // rhel-openssl-3.0.x is the engine Vercel's Node runtime needs. Without it the
  // deployed function fails at runtime with "Query engine binary not found".
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  // Pooled connection: serverless opens a connection per invocation and would
  // otherwise exhaust Postgres' connection limit.
  url       = env("DATABASE_URL")
  // Migrations must not go through the pooler.
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model Feedback {
  id        String   @id @default(cuid())
  name      String?
  email     String?
  rating    Int?
  message   String
  createdAt DateTime @default(now())
}

model Update {
  id        String   @id @default(cuid())
  title     String
  body      String
  createdAt DateTime @default(now())
}

model Devotional {
  id        String   @id @default(cuid())
  reference String
  verseText String
  note      String?
  createdAt DateTime @default(now())
}
